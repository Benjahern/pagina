# =====================================================================
# Tienda Backend — Environment Variables Template
# =====================================================================
# Copy this file to `.env` and fill in real values for local development.
# Variables marked REQUIRED have no defaults — the server refuses to
# start if any of them is empty.
#
# `.env` is gitignored. THIS file must be committed so other devs
# know what to configure.
# =====================================================================

# ---------- Server ----------
# Port the HTTP server binds to.
PORT=8080
# Gin mode: debug | release | test
GIN_MODE=debug
# Comma-separated origins allowed by CORS.
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Run the seeder on startup (true|false).
SEED=false
# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# ---------- Database (REQUIRED) ----------
DB_HOST=localhost
DB_PORT=5432
DB_USER=tienda_user
DB_PASSWORD=change_me
DB_NAME=tienda

# ---------- JWT (REQUIRED) ----------
# HS256 requires the secret to be at least 32 bytes.
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace_with_output_of_openssl_rand_base64_48_chars_min
# Token lifetime in hours.
JWT_EXPIRATION_HOURS=24
# bcrypt cost factor. Valid range: 4-31. 12 is a sane default.
BCRYPT_COST=12
